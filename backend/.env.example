# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — never commit it.

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Beyond Presence (avatar / LiveKit) — https://bey.dev
BEY_API_KEY=your-bey-api-key-here
# Single default tutor (used when BEY_AVATARS is not set)
BEY_AGENT_ID=your-bey-agent-id-here
# Optional display name for the single default tutor
# BEY_AVATAR_LABEL=Default tutor

# Multiple tutors — must be ONE line in .env (multiline values are truncated by dotenv)
# Picker photos (Option A): add frontend/public/avatars/{id}.jpg (id must match below, e.g. Fjolla.jpg)
# BEY_AVATARS=[{"id":"Fjolla","label":"Fjolla","agent_id":"uuid"},{"id":"Michael","label":"Michael","agent_id":"uuid2"},{"id":"Nelly","label":"Nelly","agent_id":"uuid3"}]
# Photos: frontend/public/avatars/{id}.png (Fjolla.png, Michael.png, …)
# BEY_DEFAULT_AVATAR_ID=Fjolla
