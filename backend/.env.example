# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — never commit it.

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Beyond Presence (avatar / LiveKit) — https://bey.dev
BEY_API_KEY=your-bey-api-key-here
# Agent id from https://app.bey.chat/myAgents (Embed / agent settings)
BEY_AGENT_ID=your-bey-agent-id-here
# Optional display name for the default tutor
# BEY_AVATAR_LABEL=Default tutor

# Multiple tutors — must be ONE line in .env
# BEY_AVATARS=[{"id":"alex","label":"Alex","agent_id":"uuid-from-bey-dashboard"}]
# BEY_DEFAULT_AVATAR_ID=alex
