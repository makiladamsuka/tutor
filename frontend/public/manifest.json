{
  "manifest_version": 3,
  "name": "TutorStream",
  "version": "1.0.0",
  "description": "Beyond Presence AI Tutor — side panel",
  "permissions": ["sidePanel"],
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Open TutorStream"
  },
  "background": {
    "service_worker": "background.js"
  }
}
