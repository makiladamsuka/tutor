{
  "manifest_version": 3,
  "name": "TutorStream",
  "version": "1.0.0",
  "description": "Beyond Presence AI Tutor — side panel",
  "permissions": ["sidePanel", "tabs"],
  "host_permissions": ["<all_urls>"],
  "side_panel": {
    "default_path": "panel.html"
  },
  "action": {
    "default_title": "Open TutorStream"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
